{
  "name": "Rag",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "convert:web": "bun run scripts/convert/convert-web.ts",
    "convert:fruit": "bun run scripts/fruit-web.ts",
    "convert:all": "bun run convert:web && bun run convert:fruit"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ]
}
